     let handle_ref = unsafe { &mut *(handle as *mut CryptoModuleHandle) };
     let encrypted_slice = unsafe { std::slice::from_raw_parts(encrypted, encrypted_len) };
     
+    // ✅ 验证 nonce_len 不会导致整数溢出
+    let nonce_len = u32::from_le_bytes([
+        encrypted_slice[0],
+        encrypted_slice[1],
+        encrypted_slice[2],
