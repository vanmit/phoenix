+// ===========================================================================
+// 安全测试用例
+// ===========================================================================
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    
+    #[test]
+    fn test_decrypt_malformed_nonce_len() {
+        // 测试恶意构造的大 nonce_len
+        let malformed = vec![0xFF, 0xFF, 0xFF, 0xFF];  // nonce_len = 4294967295
+        let mut out_len: usize = 0;
+        let result = crypto_decrypt(
+            ptr::null_mut(),
+            malformed.as_ptr(),
+            malformed.len(),
+            &mut out_len,
+        );
+        assert!(result.is_null());
+        assert_eq!(out_len, 0);
+    }
+    
+    #[test]
+    fn test_decrypt_integer_overflow() {
+        // 测试整数溢出攻击
+        let malformed = vec![0x00, 0x00, 0x01, 0x00, 0x00];  // nonce_len = 256, but total_len = 5
+        let mut out_len: usize = 0;
+        let result = crypto_decrypt(
+            ptr::null_mut(),
+            malformed.as_ptr(),
+            malformed.len(),
+            &mut out_len,
+        );
+        assert!(result.is_null());
+        assert_eq!(out_len, 0);
+    }
+    
+    #[test]
+    fn test_decrypt_short_ciphertext() {
+        // 测试密文过短
+        let mut data = vec![0x08, 0x00, 0x00, 0x00];  // nonce_len = 8
+        data.extend_from_slice(&[0u8; 8]);  // nonce
+        data.extend_from_slice(&[0u8; 4]);  // ciphertext too short (< 16 bytes)
+        let mut out_len: usize = 0;
+        let result = crypto_decrypt(
+            ptr::null_mut(),
+            data.as_ptr(),
+            data.len(),
+            &mut out_len,
+        );
+        assert!(result.is_null());
+        assert_eq!(out_len, 0);
+    }
+}
