+            *out_len = 0;
+            return ptr::null_mut();
+        }
+    };
+    
+    if data_start > encrypted_len {
+        *out_len = 0;
+        return ptr::null_mut();
+    }
+    
+    // ✅ 边界检查 4: 验证实际数据长度
+    let ciphertext = &encrypted_slice[data_start..];
+    if ciphertext.len() < 16 {  // AES-GCM 最小密文长度
+        *out_len = 0;
+        return ptr::null_mut();
+    }
+    
     let nonce = &encrypted_slice[4..4 + nonce_len];
     let ciphertext = &encrypted_slice[4 + nonce_len..];
     
