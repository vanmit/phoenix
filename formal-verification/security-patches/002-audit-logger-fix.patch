+// ===========================================================================
+// 安全测试
+// ===========================================================================
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    
+    #[test]
+    fn test_zero_trust_policy() {
+        let policy = ZeroTrustPolicy::new();
+        
+        // 测试权限检查
+        assert!(policy.verify_operation("read", 1).is_ok());
+        assert!(policy.verify_operation("admin", 5).is_err());
+        
+        // 测试数据访问
+        assert!(policy.verify_data_access("public", "none").is_ok());
+        assert!(policy.verify_data_access("secret", "internal").is_err());
+        assert!(policy.verify_data_access("secret", "secret").is_ok());
+    }
+    
+    #[test]
+    fn test_audit_logger_error_handling() {
+        let logger = AuditLogger::new();
+        
+        // 测试写入无效路径（应该降级到备用日志）
+        logger.log(AuditLevel::Info, "Test", "Test message");
+        
+        // 验证日志条目存在
+        let entries = logger.get_recent_entries(10);
+        assert!(!entries.is_empty());
+    }
+}
