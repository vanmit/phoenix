{
  "buildCommand": "cd docs/site && npm install && npm run build",
  "outputDirectory": "docs/site/.vitepress/dist",
  "devCommand": "cd docs/site && npm run dev",
  "installCommand": "cd docs/site && npm install",
  "framework": "vitepress",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*/index.html"
    },
    {
      "source": "/guide/:path*",
      "destination": "/guide/:path*/index.html"
    },
    {
      "source": "/tutorials/:path*",
      "destination": "/tutorials/:path*/index.html"
    }
  ]
}
